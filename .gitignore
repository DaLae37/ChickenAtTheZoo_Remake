# Uncomment this line if you wish to ignore the asset store tools plugin
# ChickenAtTheZoo/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
ChickenAtTheZoo/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
ChickenAtTheZoo/.vs/

# Gradle cache directory
ChickenAtTheZoo/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ChickenAtTheZoo/ExportedObj/
ChickenAtTheZoo/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
